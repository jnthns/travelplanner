rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner() {
      return request.auth != null && request.auth.uid == resource.data.userId;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // Trip: readable by any member, writable only by owner
    match /trips/{tripId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.members;
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid
                    && request.auth.uid in request.resource.data.members;
      allow update: if isOwner();
      allow delete: if isOwner();
    }

    // Child collections: access controlled by denormalized tripMembers array
    // No get() calls needed — zero extra billed reads
    match /activities/{activityId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.tripMembers;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.tripMembers;
      allow update, delete: if isAuthenticated() && request.auth.uid in resource.data.tripMembers;
    }

    match /transportRoutes/{routeId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.tripMembers;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.tripMembers;
      allow update, delete: if isAuthenticated() && request.auth.uid in resource.data.tripMembers;
    }

    match /notes/{noteId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.tripMembers;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.tripMembers;
      allow update, delete: if isAuthenticated() && request.auth.uid in resource.data.tripMembers;
    }

    match /chat_history/{messageId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.tripMembers;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.tripMembers;
      allow update, delete: if isAuthenticated() && request.auth.uid in resource.data.tripMembers;
    }

    // User directory: authenticated users can read anyone's profile;
    // users can only write their own doc
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == uid;
    }
  }
}
